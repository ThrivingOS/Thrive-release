{
  "name": "thrive-release-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-registry.mjs",
    "validate:plugin-template": "cd templates/plugin-template && npm run validate",
    "validate:skill-template": "cd templates/skill-template && npm run validate",
    "validate:pr": "node scripts/validate-pr-shape.mjs",
    "format": "prettier --write \"community*.json\" \"desktop-releases.json\""
  },
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
