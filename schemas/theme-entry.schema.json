{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ThrivingOS/Thrive-release/main/schemas/theme-entry.schema.json",
  "title": "Thrive Community Theme Entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "author", "repo", "screenshot", "modes"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "screenshot": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["dark", "light"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "publish": {
      "type": "boolean"
    },
    "legacy": {
      "type": "boolean"
    }
  }
}
